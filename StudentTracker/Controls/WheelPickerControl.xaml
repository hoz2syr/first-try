<UserControl x:Class="StudentTracker.Controls.WheelPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="230" Width="120"
             Background="Transparent"
             ClipToBounds="True">
    <Grid>
        <Canvas x:Name="ItemsCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                MouseDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseUp="Canvas_MouseUp"
                MouseLeave="Canvas_MouseLeave"
                MouseWheel="Canvas_MouseWheel"
                Cursor="Hand"/>
        <Border x:Name="SelectionBox"
                Height="46"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                IsHitTestVisible="False"
                Background="#0AFFFFFF"
                BorderBrush="#2EFFFFFF"
                BorderThickness="0,1,0,1"/>
        <Rectangle IsHitTestVisible="False" VerticalAlignment="Top" Height="115">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF000000" Offset="0"/>
                    <GradientStop Color="#A6000000" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle IsHitTestVisible="False" VerticalAlignment="Bottom" Height="115">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#A6000000" Offset="0.5"/>
                    <GradientStop Color="#FF000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>

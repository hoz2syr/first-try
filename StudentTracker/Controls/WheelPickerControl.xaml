<UserControl x:Class="StudentTracker.Controls.WheelPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="200" Width="100"
             Background="Transparent"
             ClipToBounds="True">
    <Grid>
        <Canvas x:Name="ItemsCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                MouseDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseUp="Canvas_MouseUp"
                MouseLeave="Canvas_MouseLeave"
                MouseWheel="Canvas_MouseWheel"
                Cursor="Hand"/>
        <!-- Selection highlight band -->
        <Border x:Name="SelectionBox"
                Height="42"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                IsHitTestVisible="False"
                Background="#10818CF8"
                CornerRadius="10"
                BorderBrush="#30818CF8"
                BorderThickness="1.5"
                Margin="4,0"/>
        <!-- Top fade -->
        <Rectangle IsHitTestVisible="False" VerticalAlignment="Top" Height="80">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                    <GradientStop Color="#D0FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <!-- Bottom fade -->
        <Rectangle IsHitTestVisible="False" VerticalAlignment="Bottom" Height="80">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                    <GradientStop Color="#D0FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#FFFFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>

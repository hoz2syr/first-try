<UserControl x:Class="StudentTracker.Controls.DateWheelPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StudentTracker.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             MinHeight="290"
             MinWidth="340"
             Focusable="True"
             FlowDirection="RightToLeft">

    <Border Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="16"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.08" Color="#000000" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14,18,12"
                    CornerRadius="16,16,0,0"
                    BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="اختر التاريخ"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1E293B"/>
                        <TextBlock x:Name="SelectedDatePreview"
                                   Text="—"
                                   FontSize="12.5" Foreground="#6366F1"
                                   Margin="0,3,0,0" FontWeight="Medium"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="38" Height="38"
                            CornerRadius="10"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2FF" Offset="0"/>
                                <GradientStop Color="#E0E7FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <iconPacks:PackIconMaterial Kind="CalendarMonth" 
                                                    Width="18" Height="18"
                                                    Foreground="#6366F1"
                                                    HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Wheel Columns -->
            <Grid Grid.Row="1" Margin="12,4,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Day Column -->
                <Grid Grid.Column="0">
                    <TextBlock Text="يوم" FontSize="11" Foreground="#94A3B8"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <local:WheelPickerControl x:Name="DayWheel"
                                              Height="180" Width="80"
                                              Margin="0,18,0,0"
                                              SelectionChanged="Wheel_SelectionChanged"/>
                </Grid>

                <Border Grid.Column="1" Width="1" Background="#F1F5F9" 
                        VerticalAlignment="Center" Height="100" Margin="2,12,2,0"/>

                <!-- Month Column -->
                <Grid Grid.Column="2">
                    <TextBlock Text="شهر" FontSize="11" Foreground="#94A3B8"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <local:WheelPickerControl x:Name="MonthWheel"
                                              Height="180" Width="110"
                                              Margin="0,18,0,0"
                                              SelectionChanged="Wheel_SelectionChanged"/>
                </Grid>

                <Border Grid.Column="3" Width="1" Background="#F1F5F9" 
                        VerticalAlignment="Center" Height="100" Margin="2,12,2,0"/>

                <!-- Year Column -->
                <Grid Grid.Column="4">
                    <TextBlock Text="سنة" FontSize="11" Foreground="#94A3B8"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <local:WheelPickerControl x:Name="YearWheel"
                                              Height="180" Width="80"
                                              Margin="0,18,0,0"
                                              SelectionChanged="Wheel_SelectionChanged"/>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="14,8,14,12"
                    CornerRadius="0,0,16,16"
                    BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                <Button x:Name="TodayButton"
                        HorizontalAlignment="Right"
                        Cursor="Hand"
                        Click="TodayButton_Click"
                        ToolTip="الانتقال لتاريخ اليوم">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    BorderBrush="#C7D2FE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14,6">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CalendarToday" 
                                                                Width="13" Height="13"
                                                                Foreground="#6366F1"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,6,0"/>
                                    <TextBlock Text="اليوم" FontSize="12.5" 
                                               FontWeight="Medium" Foreground="#6366F1"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EEF2FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E0E7FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</UserControl>

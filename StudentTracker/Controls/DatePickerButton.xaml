<UserControl x:Class="StudentTracker.Controls.DatePickerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StudentTracker.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             FlowDirection="RightToLeft">

    <Grid>
        <!-- The trigger button -->
        <Button x:Name="PickerButton" Click="PickerButton_Click" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="White"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DateText" Grid.Column="0"
                                       Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontSize="12" Foreground="#1E293B"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <iconPacks:PackIconMaterial Grid.Column="1" Kind="CalendarMonth" 
                                                        Width="13" Height="13" 
                                                        Foreground="#94A3B8"
                                                        VerticalAlignment="Center"
                                                        Margin="6,0,0,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- The popup with DateWheelPicker -->
        <Popup x:Name="DatePopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=PickerButton}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               HorizontalOffset="-40">
            <Border Margin="8" Background="Transparent">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
                </Border.Effect>
                <local:DateWheelPicker x:Name="InternalPicker"
                                       MinWidth="340"
                                       MinHeight="290"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>

<Window x:Class="StudentTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:StudentTracker.ViewModels"
        xmlns:converters="clr-namespace:StudentTracker.Converters"
        xmlns:controls="clr-namespace:StudentTracker.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="متابعة المسيرة الأكاديمية"
        Height="760"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <!-- ═══ المحولات (Converters) ═══ -->
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:CalendarDayBackgroundConverter x:Key="CalendarDayBackgroundConverter" />
        <converters:CalendarDayForegroundConverter x:Key="CalendarDayForegroundConverter" />
        <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverse" />
        
        <!-- ═══ جميع الأنماط والألوان مُعرّفة مركزياً في Resources/Styles.xaml ═══ -->
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ========== Decorative Background Pattern ========== -->
        <Border Grid.RowSpan="3" Opacity="0.03">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0" />
                    <GradientStop Color="#10B981" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- ========== Header with Modern Gradient ========== -->
        <Border Grid.Row="0" Padding="16,16" CornerRadius="0,0,16,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6366F1" Offset="0" />
                    <GradientStop Color="#4F46E5" Offset="0.5" />
                    <GradientStop Color="#4338CA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2" Color="#000000" Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="White" CornerRadius="12" Padding="10" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                        </Border.Effect>
                        <iconPacks:PackIconMaterial Kind="School" Width="24" Height="24" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="متتبع الطالب"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="متابعة مسيرتك الأكاديمية بسهولة"
                                   Foreground="#C7D2FE"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Click="NavDashboard_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#0D47A1" />
                                        <Setter Property="BorderBrush" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="لوحة المعلومات"/>
                        </StackPanel>
                    </Button>
                    <Button Click="NavCurrentSemester_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentSemesterActive}" Value="True">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#0D47A1" />
                                        <Setter Property="BorderBrush" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="BookOpen" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="الفصل الحالي"/>
                        </StackPanel>
                    </Button>
                    <Button Click="NavCalendar_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCalendarActive}" Value="True">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#0D47A1" />
                                        <Setter Property="BorderBrush" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="التقويم"/>
                        </StackPanel>
                    </Button>
                    <Button Click="NavOverallPlan_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverallPlanActive}" Value="True">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#0D47A1" />
                                        <Setter Property="BorderBrush" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ClipboardList" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="المخطط العام"/>
                        </StackPanel>
                    </Button>
                    <Button Click="NavNotes_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotesActive}" Value="True">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#0D47A1" />
                                        <Setter Property="BorderBrush" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="NoteText" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="الملاحظات"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="Statistics_Click"
                            VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ChartBar" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="الإحصائيات"/>
                            </StackPanel>
                        </Button>
                    <Button Click="EditPlan_Click"
                            VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="Foreground" Value="#0D47A1" />
                                            <Setter Property="BorderBrush" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="تعديل المخطط"/>
                            </StackPanel>
                        </Button>
                        <Button Click="AddNote_Click"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="NoteText" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="إضافة ملاحظة"/>
                            </StackPanel>
                        </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== Info Bar ========== -->
        <Border Grid.Row="1" Background="White" Padding="16,12" Margin="12,10,12,10" CornerRadius="12"
                BorderBrush="#E3E8EF" BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📆" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="السنة الحالية: " FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentYearText}" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,20,0" />
                    <TextBlock Text="الفصل الحالي: " FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentSemesterText}" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="16" VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Click="ChangeSemester_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Sync" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="تغيير الفصل"/>
                        </StackPanel>
                    </Button>
            </Grid>
        </Border>

        <!-- ========== Tab Content ========== -->
        <TabControl Grid.Row="2"
                Margin="12,0,12,12"
                SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                Style="{StaticResource ModernTabControlStyle}"
                MouseLeftButtonDown="TabContent_MouseDown"
                MouseLeftButtonUp="TabContent_MouseUp">

            <!-- ===== Tab 0: Dashboard ===== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="📊  نظرة عامة" Style="{StaticResource SectionTitleStyle}" />
                                <WrapPanel ItemWidth="220" ItemHeight="60">
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,0,8,8"
                                            Background="{StaticResource SuccessGradientBrush}">
                                        <TextBlock Foreground="White" FontSize="14">
                                            <Run Text="✅ "/>
                                            <Run Text="ناجحة (السنة الحالية): " />
                                            <Run Text="{Binding PassedCountCurrentYear, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,0,8,8"
                                            Background="{StaticResource DangerGradientBrush}">
                                        <TextBlock Foreground="White" FontSize="14">
                                            <Run Text="❌ "/>
                                            <Run Text="راسبة: " />
                                            <Run Text="{Binding FailedCountCurrentYear, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,0,8,8"
                                            Background="{StaticResource WarningGradientBrush}">
                                        <TextBlock Foreground="White" FontSize="14">
                                            <Run Text="⏳ معلّقة: " />
                                            <Run Text="{Binding PendingCountCurrentYear, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,0,8,8"
                                            Background="{StaticResource NeutralGradientBrush}">
                                        <TextBlock Foreground="White" FontSize="14">
                                            <Run Text="📌 متبقية: " />
                                            <Run Text="{Binding RemainingCountCurrentYear, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,0,8,8"
                                            Background="{StaticResource InfoGradientBrush}">
                                        <TextBlock Foreground="White" FontSize="14">
                                            <Run Text="📈 متوسط الدرجات: " />
                                            <Run Text="{Binding OverallAverageGradeText, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                    </Border>
                                </WrapPanel>

                                <Grid Margin="0,10,0,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="نسبة إنجاز السنة الحالية:" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <ProgressBar Grid.Column="1" Height="18" Minimum="0" Maximum="100" HorizontalAlignment="Stretch"
                                                 Value="{Binding CurrentYearCompletionPercentage, Mode=OneWay}"
                                                 Style="{StaticResource ModernProgressBarStyle}"
                                                 Foreground="{StaticResource PrimaryBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentYearCompletionText}" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="16" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="💡  تلميح" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="24">
                                    <Run Text="🖱️ استخدم أزرار التنقل بالأعلى للانتقال السريع بين الأقسام." />
                                    <LineBreak />
                                    <Run Text="👆 يمكنك السحب يميناً أو يساراً للتنقل بين التبويبات." />
                                    <LineBreak />
                                    <Run Text="✏️ اضغط على زر 'تعديل' في بطاقة المادة لتعديل الدرجات مباشرة." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Tab 1: Current Semester ===== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                    <ItemsControl ItemsSource="{Binding CurrentSemesterSubjects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewmodels:SubjectViewModel}">
                                <Border Margin="0,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="Padding" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRetakeLab}" Value="True">
                                                    <Setter Property="Background" Value="#FFF9C4" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Background" Value="#F0F4FF" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="16,12"
                                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SubjectName}" FontWeight="Bold" FontSize="17" Foreground="White" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                    <TextBlock Text="✏️ تعديل" Foreground="#FFD54F" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="{Binding FinalGradeText}" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Data table with inline view/edit -->
                                        <Grid Grid.Row="1" Margin="16,12,16,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Column headers -->
                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="" />
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="العملي" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                            <TextBlock Grid.Column="2" Grid.Row="0" Text="النظري" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />

                                            <!-- Row 1: Grades -->
                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="العلامة" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4" />

                                            <!-- View mode grades -->
                                            <Border Grid.Column="1" Grid.Row="1" Background="#F0F4F8" CornerRadius="8" Padding="10,6" Margin="4,2" HorizontalAlignment="Center" MinWidth="65"
                                                    Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}"
                                                    Cursor="Hand" ToolTip="اضغط زر 'تعديل' لتغيير العلامة">
                                                <TextBlock Text="{Binding PracticalGradeText}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15" />
                                            </Border>
                                            <Border Grid.Column="2" Grid.Row="1" Background="#F0F4F8" CornerRadius="8" Padding="10,6" Margin="4,2" HorizontalAlignment="Center" MinWidth="65"
                                                    Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}"
                                                    Cursor="Hand" ToolTip="اضغط زر 'تعديل' لتغيير العلامة">
                                                <TextBlock Text="{Binding TheoryGradeText}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15" />
                                            </Border>

                                            <!-- Edit mode grades -->
                                            <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding EditPracticalGrade, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InlineTextBoxStyle}"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding EditTheoryGrade, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InlineTextBoxStyle}"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />

                                            <!-- Row 2: Exam dates -->
                                            <TextBlock Grid.Column="0" Grid.Row="2" Text="موعد الامتحان" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4" />

                                            <!-- View mode dates -->
                                            <Border Grid.Column="1" Grid.Row="2" Background="#F0F4F8" CornerRadius="8" Padding="8,6" Margin="4,2" HorizontalAlignment="Stretch"
                                                    Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding PracticalExamDateText}" HorizontalAlignment="Center" FontSize="12" />
                                            </Border>
                                            <Border Grid.Column="2" Grid.Row="2" Background="#F0F4F8" CornerRadius="8" Padding="8,6" Margin="4,2" HorizontalAlignment="Stretch"
                                                    Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding TheoryExamDateText}" HorizontalAlignment="Center" FontSize="12" />
                                            </Border>

                                            <!-- Edit mode dates -->
                                            <Grid Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch" Margin="2,1"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <controls:DatePickerButton Grid.Column="0" SelectedDate="{Binding EditPracticalExamDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                                            VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Text="{Binding EditPracticalExamTime, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SmallInlineTextBoxStyle}" ToolTip="الوقت hh:mm" VerticalAlignment="Center" FontSize="10" Width="50" Margin="2,0,0,0" />
                                            </Grid>
                                            <Grid Grid.Column="2" Grid.Row="2" HorizontalAlignment="Stretch" Margin="2,1"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <controls:DatePickerButton Grid.Column="0" SelectedDate="{Binding EditTheoryExamDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                            VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Text="{Binding EditTheoryExamTime, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SmallInlineTextBoxStyle}" ToolTip="الوقت hh:mm" VerticalAlignment="Center" FontSize="10" Width="50" Margin="2,0,0,0" />
                                            </Grid>
                                        </Grid>

                                        <!-- Action buttons -->
                                        <Border Grid.Row="2" Padding="16,8,16,12">
                                            <StackPanel>
                                                <!-- View mode buttons -->
                                                <WrapPanel Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                                    <Button Command="{Binding AddGradeCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource SuccessDarkBrush}" ToolTip="إضافة درجة">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="Plus" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="إضافة درجة" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding AddExamCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource WarningBrush}" ToolTip="إضافة امتحان">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="CalendarPlus" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="إضافة امتحان" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding StartEditCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource PrimaryBrush}" ToolTip="تعديل">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ShowHistoryCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource NeutralBrush}" ToolTip="السجل">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="FileDocument" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="السجل" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding RetakeLabCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource DangerBrush}"
                                                            ToolTip="إعادة عملي"
                                                            Visibility="{Binding ShowRetakeLabButton, Converter={StaticResource BoolToVisibility}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="إعادة عملي" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </WrapPanel>
                                                <!-- Edit mode buttons -->
                                                <WrapPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                    <Button Command="{Binding SaveEditCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource SuccessDarkBrush}" ToolTip="حفظ">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding CancelEditCommand}" Style="{StaticResource SubjectButtonStyle}"
                                                            Background="{StaticResource NeutralBrush}" ToolTip="إلغاء">
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                    <!-- Empty state message when there are no subjects -->
                    <TextBlock Text="لا توجد مواد في الفصل الحالي" FontStyle="Italic" Foreground="#777" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSemesterSubjects.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Tab 2: Overall Plan ===== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Overall summary card -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="📋  الإنجاز الكلي" Style="{StaticResource SectionTitleStyle}" />
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold">
                                        <Run Text="المواد الناجحة: " />
                                        <Run Text="{Binding OverallPassedCount, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource SuccessDarkBrush}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding OverallTotalCount, Mode=OneWay}" />
                                    </TextBlock>
                                    <ProgressBar Grid.Column="1" Height="18" Minimum="0" Maximum="100" HorizontalAlignment="Stretch"
                                                 Value="{Binding OverallCompletionPercentage, Mode=OneWay}"
                                                 Foreground="{StaticResource SuccessDarkBrush}" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" />
                                    <TextBlock Grid.Column="2" Text="{Binding OverallCompletionText}" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="16" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Semester groups -->
                        <ItemsControl ItemsSource="{Binding GeneralPlanSemesters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:SemesterGroupViewModel}">
                                    <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                                        <StackPanel>
                                            <!-- Semester header -->
                                            <Border CornerRadius="12,12,0,0" Padding="16,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0" />
                                                        <GradientStop Color="{StaticResource PrimaryLightColor}" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Header}" FontWeight="Bold" FontSize="16" Foreground="White" />
                                            </Border>

                                            <!-- Column headers -->
                                            <Grid Margin="16,0" MinHeight="36">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="140" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="Transparent" />
                                                <TextBlock Grid.Column="1" Text="المادة" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="عملي" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="نظري" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="المجموع" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="امتحان عملي" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="6" Text="امتحان نظري" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="7" Text="إجراءات" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Subjects}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type viewmodels:SubjectViewModel}">
                                                        <Border BorderBrush="#EEF2F7" BorderThickness="0,0,0,1" Padding="0,2" Margin="16,0">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <!-- Display row -->
                                                                <Grid Grid.Row="0" MinHeight="40">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="24" />
                                                                        <ColumnDefinition Width="2*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="100" />
                                                                        <ColumnDefinition Width="100" />
                                                                        <ColumnDefinition Width="140" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" CornerRadius="4" Margin="0,5" />
                                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding SubjectName}" FontWeight="SemiBold" FontSize="13" />
                                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding PracticalGradeText}" FontSize="13" />
                                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding TheoryGradeText}" FontSize="13" />
                                                                    <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding FinalGradeText}" FontWeight="Bold" FontSize="13" />
                                                                    <TextBlock Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding PracticalExamDateText}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PracticalExamDateText}" />
                                                                    <TextBlock Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding TheoryExamDateText}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding TheoryExamDateText}" />
                                                                    <!-- View mode buttons -->
                                                                    <WrapPanel Grid.Column="7" VerticalAlignment="Center" Margin="2,0" HorizontalAlignment="Center" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                                                        <Button Command="{Binding AddGradeCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource SuccessDarkBrush}" ToolTip="إضافة درجة">
                                                                            <iconPacks:PackIconMaterial Kind="Plus" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                        <Button Command="{Binding AddExamCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource WarningBrush}" ToolTip="إضافة امتحان">
                                                                            <iconPacks:PackIconMaterial Kind="CalendarPlus" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                        <Button Command="{Binding StartEditCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource PrimaryBrush}" ToolTip="تعديل">
                                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                        <Button Command="{Binding ShowHistoryCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource NeutralBrush}" ToolTip="السجل">
                                                                            <iconPacks:PackIconMaterial Kind="FileDocument" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                    </WrapPanel>
                                                                </Grid>
                                                                <!-- Edit row spanning all columns -->
                                                                <Grid Grid.Row="1" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" Margin="16,8,16,8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="24" />
                                                                        <ColumnDefinition Width="2*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="100" />
                                                                        <ColumnDefinition Width="100" />
                                                                        <ColumnDefinition Width="140" />
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <!-- Empty status column for edit mode -->
                                                                    <Border Grid.Column="0" />
                                                                    
                                                                    <!-- Subject name (read-only in edit) -->
                                                                    <TextBlock Grid.Column="1" Text="{Binding SubjectName}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                    
                                                                    <!-- Practical grade -->
                                                                    <TextBox Grid.Column="2" Text="{Binding EditPracticalGrade, UpdateSourceTrigger=PropertyChanged}"
                                                                             Style="{StaticResource InlineTextBoxStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="70" />
                                                                    
                                                                    <!-- Theory grade -->
                                                                    <TextBox Grid.Column="3" Text="{Binding EditTheoryGrade, UpdateSourceTrigger=PropertyChanged}"
                                                                             Style="{StaticResource InlineTextBoxStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="70" />
                                                                    
                                                                    <!-- Final grade (calculated) -->
                                                                    <TextBlock Grid.Column="4" Text="{Binding FinalGradeText}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                    
                                                                    <!-- Practical exam date -->
                                                                    <StackPanel Grid.Column="5" Orientation="Vertical" VerticalAlignment="Center" Margin="2,0">
                                                                        <controls:DatePickerButton SelectedDate="{Binding EditPracticalExamDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                                                        <TextBox Text="{Binding EditPracticalExamTime, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Style="{StaticResource SmallInlineTextBoxStyle}" FontSize="10" Padding="2" Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                    
                                                                    <!-- Theory exam date -->
                                                                    <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center" Margin="2,0">
                                                                        <controls:DatePickerButton SelectedDate="{Binding EditTheoryExamDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                                                        <TextBox Text="{Binding EditTheoryExamTime, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Style="{StaticResource SmallInlineTextBoxStyle}" FontSize="10" Padding="2" Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                    
                                                                    <!-- Action buttons -->
                                                                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <Button Command="{Binding SaveEditCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource SuccessDarkBrush}" ToolTip="حفظ">
                                                                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                        <Button Command="{Binding CancelEditCommand}" Style="{StaticResource CompactIconButtonStyle}" Background="{StaticResource NeutralBrush}" ToolTip="إلغاء">
                                                                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13" Foreground="White"/>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- ===== Tab 3: Calendar ===== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Calendar Header -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <!-- Month Navigation -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Content="&#x25C0;" Click="PreviousMonth_Click" 
                                            Padding="12,8" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderBrush="{StaticResource PrimaryDarkBrush}" FontSize="16" />
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentMonthName}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="  " />
                                        <TextBlock Text="{Binding CurrentCalendarYear}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2" Content="&#x25B6;" Click="NextMonth_Click" 
                                            Padding="12,8" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderBrush="{StaticResource PrimaryDarkBrush}" FontSize="16" />
                                </Grid>
                                
                                <!-- Day Headers -->
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Weekday headers -->
                                    <UniformGrid Grid.Row="0" Rows="1" Columns="7" Margin="0,0,0,8">
                                        <TextBlock Text="الأحد" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="الاثنين" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="الثلاثاء" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="الأربعاء" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="الخميس" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="الجمعة" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource DangerDarkBrush}" />
                                        <TextBlock Text="السبت" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource DangerDarkBrush}" />
                                    </UniformGrid>
                                    
                                    <!-- Calendar Days -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewmodels:CalendarDayViewModel}">
                                                <Border BorderBrush="#E3E8EF" BorderThickness="0.5" Margin="1" CornerRadius="6" 
                                                        MinHeight="80" Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="White" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="Background" Value="#E3F2FD" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="#1565C0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                    <Setter Property="Background" Value="#F5F5F5" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectCalendarDayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <Grid Margin="4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        
                                                        <!-- Day Number -->
                                                        <TextBlock Grid.Row="0" Text="{Binding DayNumber}" FontSize="14" FontWeight="SemiBold" 
                                                                   HorizontalAlignment="Center" Margin="0,2,0,4">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#37474F" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="White" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                            <Setter Property="Foreground" Value="#B0BEC5" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        
                                                        <!-- Events -->
                                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Events}" VerticalAlignment="Top">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="3" Padding="2" Margin="0,1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding DisplayText}" FontSize="9" Foreground="White" 
                                                                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <!-- Selected Day Events -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDayEvents}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="تفاصيل المواعيد" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding SelectedDayEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E3E8EF" BorderThickness="0,0,0,1" Padding="8" Margin="0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding SubjectName}" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="{Binding ExamType}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding TimeText}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        
                        <!-- Legend -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border CornerRadius="4" Padding="8,4" Margin="4,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD" />
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="اليوم الحالي" FontSize="12" />
                                </Border>
                                <Border CornerRadius="4" Padding="8,4" Margin="4,0" Background="{StaticResource PrimaryBrush}">
                                    <TextBlock Text="اليوم المحدد" FontSize="12" Foreground="White" />
                                </Border>
                                <Border CornerRadius="4" Padding="8,4" Margin="4,0" Background="#F5F5F5">
                                    <TextBlock Text="شهر آخر" FontSize="12" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ===== Tab 4: Notes ===== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Notes Header -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0" />
                                    <GradientStop Color="#8B5CF6" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Background="White" CornerRadius="14" Padding="14" Margin="0,0,16,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                                            </Border.Effect>
                                            <iconPacks:PackIconMaterial Kind="NoteText" Width="28" Height="28" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="📝  ملاحظاتي" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="احتفظ بأفكارك وملاحظاتك المهمة" FontSize="16" Foreground="#E0E7FF"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Click="AddNote_Click" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding" Value="24,14" />
                                            <Setter Property="FontSize" Value="16" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15" Padding="{TemplateBinding Padding}">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#000000" Direction="270" />
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#F0F4FF" />
                                                                <Setter TargetName="border" Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="20" Height="20" Margin="0,0,10,0"/>
                                        <TextBlock Text="إضافة ملاحظة"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Notes List -->
                        <ItemsControl ItemsSource="{Binding Notes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,16" Background="White" CornerRadius="16" Padding="0" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#000000" Direction="270" />
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Header -->
                                            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="20,16">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#F8FAFC" Offset="0" />
                                                        <GradientStop Color="#F1F5F9" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                                            <iconPacks:PackIconMaterial Kind="NoteText" Width="16" Height="16" Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" Foreground="#1A202C" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding CreatedDateText}" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <Button Grid.Column="2" Click="DeleteNote_Click" ToolTip="حذف الملاحظة" Cursor="Hand"
                                                            VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="Padding" Value="6" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="bd" Property="Background" Value="#FEE2E2" />
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <iconPacks:PackIconMaterial Kind="TrashCan" Width="16" Height="16" Foreground="#EF4444"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Content -->
                                            <Border Grid.Row="1" Padding="20,16,20,20">
                                                <TextBlock Text="{Binding ShortContent}" TextWrapping="Wrap" FontSize="15" Foreground="#475569" LineHeight="24" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <Border Style="{StaticResource CardBorderStyle}" Visibility="{Binding Notes.Count, Converter={StaticResource BoolToVisibilityInverse}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F8FAFC" Offset="0" />
                                    <GradientStop Color="#F1F5F9" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="60,50">
                                <Border Background="#E2E8F0" CornerRadius="60" Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,25">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="#000000" Direction="270" />
                                    </Border.Effect>
                                    <iconPacks:PackIconMaterial Kind="NoteText" Width="60" Height="60" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="لا توجد ملاحظات بعد" FontSize="24" FontWeight="Bold" Foreground="#2D3748" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="ابدأ بإضافة ملاحظتك الأولى لحفظ أفكارك وملاحظاتك المهمة" FontSize="16" Foreground="#64748B" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="450" Margin="0,0,0,30"/>
                                <Button Click="AddNote_Click" 
                                        Background="{StaticResource PrimaryBrush}" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="30,16" FontSize="16" FontWeight="Bold">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="20" Height="20" Margin="0,0,10,0"/>
                                        <TextBlock Text="إضافة ملاحظة جديدة"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>


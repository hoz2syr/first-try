<Window x:Class="StudentTracker.Windows.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        FlowDirection="RightToLeft"
        Title="الإعداد الأولي - خطة الطالب"
        MinHeight="650"
        MinWidth="800"
        Height="800"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Border Background="#FFF" Padding="0" CornerRadius="20" Margin="24" Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header مع تدرج لوني محسن -->
            <Border Grid.Row="0" Padding="32,28" CornerRadius="20,20,0,0"
                    Background="{StaticResource HeaderGradientBrush}">
                <StackPanel HorizontalAlignment="Center">
                    <Border Background="#FFFFFF22" CornerRadius="50" Padding="16" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterial Kind="SchoolOutline" Width="48" Height="48" Foreground="White"/>
                    </Border>
                    <TextBlock Text="مرحباً بك في تطبيق خطة الطالب"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="قم بإعداد خطتك الدراسية لمتابعة مسيرتك الأكاديمية بسهولة"
                               FontSize="15"
                               Foreground="#E0E7FF"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="28,20,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- إعدادات السنوات والفصول -->
                <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="16" Padding="24" Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- عدد السنوات -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <iconPacks:PackIconMaterial Kind="CalendarClock" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="عدد السنوات الدراسية" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="أدخل عدد السنوات التي ستدرسها (مثال: 4 سنوات)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <ComboBox x:Name="YearsComboBox" Width="200" Height="40" FontSize="15" Padding="12,8" 
                                      SelectionChanged="YearsComboBox_SelectionChanged" SelectedIndex="0">
                                <ComboBoxItem Content="سنة واحدة" Tag="1"/>
                                <ComboBoxItem Content="سنتان" Tag="2"/>
                                <ComboBoxItem Content="3 سنوات" Tag="3"/>
                                <ComboBoxItem Content="4 سنوات" Tag="4"/>
                                <ComboBoxItem Content="5 سنوات" Tag="5"/>
                                <ComboBoxItem Content="6 سنوات" Tag="6"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- خط فاصل -->
                        <Border Grid.Column="1" Width="1" Background="#E2E8F0" Margin="24,0"/>

                        <!-- عدد الفصول -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="عدد الفصول في كل سنة" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="معظم الجامعات لها فصلين أو 3 فصول سنوياً" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <ComboBox x:Name="SemestersComboBox" Width="200" Height="40" FontSize="15" Padding="12,8" 
                                      SelectionChanged="SemestersComboBox_SelectionChanged" SelectedIndex="1">
                                <ComboBoxItem Content="فصل واحد" Tag="1"/>
                                <ComboBoxItem Content="فصلان" Tag="2"/>
                                <ComboBoxItem Content="3 فصول (فصل صيفي)" Tag="3"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- نصائح سريعة -->
                <Border Grid.Row="1" Background="#EFF6FF" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#BFDBFE" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="LightbulbOnOutline" Width="22" Height="22" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock FontSize="13" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold">💡 نصيحة:</Run>
                            <Run>أضف المواد التي ستدرسها في كل فصل. يمكنك تعديل الخطة لاحقاً من الشاشة الرئيسية.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- منطقة إدخال المواد -->
                <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="16" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="المواد الدراسية" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TablesHost">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- أزرار الإجراءات -->
                <Grid Grid.Row="3" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- معلومات إضافية -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="16" Height="16" Foreground="{StaticResource NeutralBrush}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="InfoText" Text="أدخل عدد السنوات والفصول للبدء" FontSize="13" Foreground="{StaticResource NeutralBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="CancelButton" Width="120" Height="44" FontSize="14" FontWeight="SemiBold" 
                                Click="Cancel_Click" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource NeutralDarkBrush}" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="إلغاء"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveButton" Width="180" Height="44" FontSize="15" FontWeight="SemiBold" IsEnabled="False" Click="SaveAndStart_Click"
                                Background="{StaticResource PrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Check" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="حفظ ومتابعة"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>


<Window x:Class="StudentTracker.Windows.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="الإعداد الأولي"
        MinHeight="600"
        MinWidth="700"
        Height="780"
        Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">
    <Border Background="#FFF" Padding="0" CornerRadius="18" Margin="32" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,24" CornerRadius="18,18,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#283593" Offset="0" />
                        <GradientStop Color="#1976D2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10" >
                    <iconPacks:PackIconMaterial Kind="School" Width="44" Height="44" Foreground="White"/>
                </TextBlock>
                    <TextBlock Text="مرحباً، لنبدأ بإعداد خطتك الدراسية"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="أدخل بيانات خطتك الأكاديمية لبدء متابعة مسيرتك"
                               FontSize="15"
                               Foreground="#BBDEFB"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="#F5F7FA" CornerRadius="14" Padding="24" Margin="0,0,0,18" BorderBrush="#E3E8EF" BorderThickness="1" >
                    <UniformGrid Columns="2" Rows="1" HorizontalAlignment="Center" VerticalAlignment="Center" >
                        <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="عدد السنوات الدراسية" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4" />
                            <TextBox x:Name="YearsTextBox" Width="180" Height="34" FontSize="15" Padding="8,2" PreviewTextInput="NumbersOnly_PreviewTextInput" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="عدد الفصول في كل سنة" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4" />
                            <TextBox x:Name="SemestersTextBox" Width="180" Height="34" FontSize="15" Padding="8,2" Text="2" PreviewTextInput="NumbersOnly_PreviewTextInput" />
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                    <StackPanel x:Name="TablesHost" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button x:Name="SaveButton" Width="180" Height="44" FontSize="16" FontWeight="Bold" IsEnabled="False" Click="SaveAndStart_Click"
                            Background="#388E3C" BorderBrush="#1B5E20" Foreground="White" Cursor="Hand" >
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="RocketLaunch" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="حفظ ومتابعة"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>


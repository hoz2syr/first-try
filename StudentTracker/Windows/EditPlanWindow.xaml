<Window x:Class="StudentTracker.Windows.EditPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="تعديل المخطط العام"
        Height="720"
        Width="920"
        WindowStartupLocation="CenterOwner">
    <Border Background="#EEF2F7" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontWeight="Bold" FontSize="20" Foreground="White" >
                    <iconPacks:PackIconMaterial Kind="Cog" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Run Text="تعديل المخطط العام"/>
                </TextBlock>
                    <TextBlock Text="إضافة وتعديل المواد — لا يتم حذف العلامات أو إعادة بناء البيانات السابقة" Foreground="#BBDEFB" FontSize="13" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12" BorderBrush="#E3E8EF" BorderThickness="1"
                        Effect="{StaticResource CardShadow}">
                    <WrapPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="عدد السنوات الدراسية" FontWeight="SemiBold" />
                            <TextBox x:Name="YearsTextBox" Width="170" Text="" />
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="عدد الفصول في كل سنة" FontWeight="SemiBold" />
                            <TextBox x:Name="SemestersTextBox" Width="170" Text="2" />
                        </StackPanel>
                        <Button Width="160" VerticalAlignment="Bottom" Click="BuildTables_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Table" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إنشاء الجداول"/>
                    </StackPanel>
                </Button>
                    </WrapPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TablesHost" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button Width="130" Click="Save_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>
                <Button Width="130" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إغلاق"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>


<Window x:Class="StudentTracker.Windows.GraduationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="مبارك التخرج"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="680"
        Height="520"
        ResizeMode="NoResize">
    <Border Background="#EEF2F7" CornerRadius="20">
        <Grid>
            <!-- Background overlay -->
            <Border Background="#80000000" CornerRadius="20" Opacity="0.5" />
            
            <!-- Main content -->
            <Border CornerRadius="20" Margin="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B5E20" Offset="0" />
                        <GradientStop Color="#2E7D32" Offset="0.5" />
                        <GradientStop Color="#388E3C" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <!-- Confetti decoration -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" Opacity="0.25">
                        <iconPacks:PackIconMaterial Kind="School" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="StarOutline" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="TrophyVariant" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="StarOutline" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="School" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="28" Height="28" Foreground="White" Margin="4,0"/>
                    </StackPanel>
                    
                    <!-- Main content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Icon -->
                        <TextBlock FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,16" >
                        <iconPacks:PackIconMaterial Kind="School" Width="80" Height="80" Foreground="#FFD700"/>
                    </TextBlock>
                        
                        <!-- Title -->
                        <TextBlock Text="مبارك التخرج!" 
                                   FontSize="44" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.4" Color="Black" />
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <!-- Subtitle -->
                        <TextBlock Text="أتممت جميع مواد مسيرتك الأكاديمية بنجاح&#x0a;هذا الإنجاز ثمرة جهدك وتفانيك" 
                                   FontSize="18" 
                                   Foreground="#C8E6C9" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   LineHeight="28" />
                        
                        <!-- Stats badge -->
                        <Border Background="#40FFFFFF" 
                                CornerRadius="12" 
                                Padding="20,16" 
                                Margin="0,24,0,36"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="StatsTextBlock" FontSize="18" FontWeight="Bold" Foreground="White" >
                                    <iconPacks:PackIconMaterial Kind="CheckCircle" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <Run Text=""/>
                                    <Run Text="مادة مكتملة من أصل "/>
                                    <Run Text="48" FontWeight="Bold"/>
                                </TextBlock>
                        </Border>
                        
                        <!-- Continue button -->
                        <Button Click="Continue_Click"
                                HorizontalAlignment="Center"
                                Padding="28,14"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="White"
                                Foreground="#1B5E20"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="50"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Check" Width="18" Height="18" Margin="0,0,8,0" Foreground="#2E7D32"/>
                                <TextBlock Text="شكراً، إلى الأمام!"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


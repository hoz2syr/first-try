<Window x:Class="StudentTracker.Windows.DateTimeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudentTracker.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="اختر التاريخ والوقت" 
        Height="420" 
        Width="400" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">
    <Border Background="#EEF2F7" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock FontWeight="Bold" FontSize="18" Foreground="White" >
                    <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Run Text="اختر التاريخ والوقت"/>
                </TextBlock>
            </Border>

            <Grid Grid.Row="1" Margin="18,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- التاريخ -->
                <StackPanel Grid.Row="0" Margin="0,0,0,14" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Vertical" Width="260">
                        <TextBlock Text="التاريخ" FontWeight="SemiBold" FontSize="14" Foreground="#546E7A" Margin="0,0,0,6" />
                        <DatePicker x:Name="DatePickerControl" 
                                    Language="en-US" 
                                    FontSize="14" 
                                    Padding="10,8" />
                    </StackPanel>
                    <Button Content="اليوم" 
                            Width="80" 
                            Height="36" 
                            Margin="12,18,0,0" 
                            FontSize="13"
                            Padding="8,6"
                            Click="TodayButton_Click" />
                </StackPanel>

                <!-- الوقت - iOS Wheel Picker Style -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="الوقت" FontWeight="SemiBold" FontSize="14" Foreground="#546E7A" Margin="0,0,0,8" />
                    
                    <!-- Wheel Picker Container -->
                    <Border Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="20" 
                            Height="180"
                            Padding="12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.06" Color="#000000" Direction="270" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Hours Wheel -->
                            <Border Grid.Column="0" Background="Transparent" CornerRadius="12">
                                <controls:WheelPickerControl x:Name="HoursWheelPicker" 
                                                              Width="110" 
                                                              Height="156"
                                                              Margin="6,0,0,0"
                                                              SelectionChanged="Picker_SelectionChanged" />
                            </Border>
                            
                            <!-- Separator -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,0">
                                <Ellipse Width="4" Height="4" Fill="#1565C0" Margin="0,0,0,4"/>
                                <Ellipse Width="4" Height="4" Fill="#1565C0" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Minutes Wheel -->
                            <Border Grid.Column="2" Background="Transparent" CornerRadius="12">
                                <controls:WheelPickerControl x:Name="MinutesWheelPicker" 
                                                              Width="110" 
                                                              Height="156"
                                                              Margin="0,0,6,0"
                                                              SelectionChanged="Picker_SelectionChanged" />
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Time Format Hint -->
                    <TextBlock Text="اسحب لاختيار الوقت" 
                               FontSize="12" 
                               Foreground="#78909C" 
                               HorizontalAlignment="Center" 
                               Margin="0,8,0,0" />
                </StackPanel>

                <!-- الوقت المحدد -->
                <TextBlock x:Name="SelectedTimeText" 
                           Grid.Row="2"
                           Text="09:00" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#1565C0" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,12" />

                <!-- الأزرار -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Width="110" Click="OkButton_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>
                <Button Width="110" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>


<Window x:Class="StudentTracker.Windows.AddExamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="إدخال موعد امتحان"
        Height="360"
        Width="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="#EEF2F7" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14" CornerRadius="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="{Binding SubjectName}" FontWeight="Bold" FontSize="18" Foreground="White" />
            </Border>

            <Grid Grid.Row="1" Margin="18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="نوع الامتحان" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="8,6">
                        <RadioButton x:Name="PracticalRadio" Content="عملي" IsChecked="True" Margin="0,0,16,0" />
                        <RadioButton x:Name="TheoryRadio" Content="نظري" />
                    </StackPanel>
                </GroupBox>

                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,10">
                    <TextBlock Text="التاريخ والوقت" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ExamDateTimeTextBox" IsReadOnly="True" Width="160" Margin="0,0,8,0" Style="{StaticResource ValidatedTextBoxStyle}" />
                        <Button Content="اختيار..." Width="80" Click="PickDateTime_Click" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="2" Style="{StaticResource HintTextStyle}"
                           Text="سيتم التحقق من تعارض نفس اليوم والساعة مع أي امتحان آخر." />

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                    <Button Width="110" Click="Save_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>
                <Button Width="110" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>


<Window x:Class="StudentTracker.Windows.AddExamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudentTracker.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        FlowDirection="RightToLeft"
        Title="إدخال موعد امتحان"
        Height="620"
        Width="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="White" CornerRadius="20" Margin="12"
            BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.12" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="22,18" CornerRadius="20,20,0,0"
                    Background="{StaticResource HeaderGradientBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="إضافة موعد امتحان" FontWeight="Bold" FontSize="18" Foreground="White"/>
                        <TextBlock Text="{Binding SubjectName}" FontSize="14" Foreground="#C7D2FE" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#FFFFFF20" CornerRadius="12" Padding="10">
                        <iconPacks:PackIconMaterial Kind="CalendarPlus" Width="22" Height="22" Foreground="White"/>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,16,22,20">
                    <!-- نوع الامتحان -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="FormatListBulleted" Width="15" Height="15" 
                                                        Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="نوع الامتحان" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PracticalRadio" Content="عملي" IsChecked="True" 
                                             Margin="0,0,30,0" FontSize="14" Cursor="Hand"/>
                                <RadioButton x:Name="TheoryRadio" Content="نظري" FontSize="14" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- التاريخ -->
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="15" Height="15" 
                                                        Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="التاريخ" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <controls:DateWheelPicker x:Name="ExamDatePicker"
                                                  HorizontalAlignment="Stretch"
                                                  MinHeight="290"/>
                    </StackPanel>

                    <!-- الوقت -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="ClockOutline" Width="15" Height="15" 
                                                        Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="الوقت" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,10" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="HourTextBox" Text="09" 
                                         Style="{StaticResource ValidatedTextBoxStyle}" 
                                         FontSize="20" FontWeight="Bold" 
                                         HorizontalContentAlignment="Center"
                                         MaxLength="2" Width="65"/>
                                <TextBlock Grid.Column="1" Text=":" FontSize="22" FontWeight="Bold" 
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="MinuteTextBox" Text="00" 
                                         Style="{StaticResource ValidatedTextBoxStyle}" 
                                         FontSize="20" FontWeight="Bold" 
                                         HorizontalContentAlignment="Center"
                                         MaxLength="2" Width="65"/>
                                <TextBlock Grid.Column="3" 
                                           Text="(24 ساعة)" FontSize="12" Foreground="{StaticResource MutedBrush}" 
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <TextBlock Style="{StaticResource HintTextStyle}"
                               Text="سيتم التحقق من تعارض نفس اليوم والساعة مع أي امتحان آخر." Margin="0,0,0,8"/>

                    <!-- الأزرار -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Click="Cancel_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#F8FAFC" CornerRadius="10" 
                                            Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="15" Height="15" 
                                                                        Foreground="#64748B" Margin="0,0,6,0"/>
                                            <TextBlock Text="إلغاء" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Grid.Column="2" Click="Save_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="10" Padding="16,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#818CF8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="15" Height="15" 
                                                                        Foreground="White" Margin="0,0,6,0"/>
                                            <TextBlock Text="حفظ" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>


<Window x:Class="StudentTracker.Windows.AddNoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:StudentTracker.Controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        FlowDirection="RightToLeft"
        Title="إضافة ملاحظة"
        Height="580"
        Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <!-- جميع الأنماط مُعرّفة مركزياً في Resources/Styles.xaml -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="30,22"
                Background="{StaticResource HeaderGradientBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#000000" Direction="270" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="White" CornerRadius="14" Padding="14" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                    </Border.Effect>
                    <iconPacks:PackIconMaterial Kind="NoteEdit" Width="30" Height="30" Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إضافة ملاحظة جديدة" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="سجّل أفكارك وملاحظاتك المهمة" FontSize="14" Foreground="#C7D2FE" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,25">
                <!-- Title -->
                <StackPanel Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="FormatTitle" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="عنوان الملاحظة" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBox x:Name="TitleTextBox" 
                             Height="50" 
                             Style="{StaticResource ValidatedTextBoxStyle}"
                             MaxLength="100"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             FontWeight="SemiBold"
                             FontSize="16"
                             TabIndex="0"
                             ToolTip="أدخل عنوان الملاحظة (مطلوب)"/>
                    <TextBlock Text="مثال: ملاحظات المحاضرة، أفكار المشروع، تذكيرات مهمة" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               Margin="5,5,0,0"
                               FontStyle="Italic"/>
                </StackPanel>

                <!-- Content -->
                <StackPanel Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="TextBox" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="محتوى الملاحظة" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="*" Foreground="#EF4444" FontWeight="Bold" FontSize="16" Margin="4,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="ContentTextBox" 
                             MinHeight="200"
                             MaxHeight="400"
                             Style="{StaticResource ValidatedTextBoxStyle}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             MaxLength="2000"
                             TabIndex="1"
                             Text=""
                             ToolTip="اكتب محتوى الملاحظة هنا (مطلوب)"
                             SpellCheck.IsEnabled="True"/>
                    <StackPanel Orientation="Horizontal" Margin="5,8,0,0">
                        <TextBlock Text="💡 نصيحة: استخدم Enter لسطر جديد، يمكنك كتابة قوائم ونقاط" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontStyle="Italic"/>
                        <TextBlock x:Name="CharacterCountText" 
                                   Text="0/2000" 
                                   FontSize="12" 
                                   Foreground="{StaticResource MutedBrush}" 
                                   HorizontalAlignment="Right"
                                   FontWeight="SemiBold"
                                   Margin="15,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Date -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="Calendar" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تاريخ الملاحظة" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <controls:DateWheelPicker x:Name="NoteDatePicker"
                                              Height="200"
                                              HorizontalAlignment="Stretch"
                                              SelectedDate="{Binding NoteDate, Mode=OneWay}"
                                              TabIndex="2"
                                              ToolTip="اختر تاريخ الملاحظة"/>
                    <TextBlock Text="التاريخ الافتراضي هو اليوم" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               Margin="5,5,0,0"
                               FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="White" Padding="30,20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel>
                <!-- Help Text -->
                <Border Background="#EFF6FF" BorderBrush="{StaticResource InfoBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="16" Height="16" Foreground="{StaticResource InfoBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="12" Foreground="#1E40AF">
                            <Run Text="نصائح:" FontWeight="SemiBold"/>
                            <Run Text="Ctrl+Enter للحفظ • Esc للإلغاء • يجب إدخال عنوان ومحتوى الملاحظة"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SaveButton" 
                            Click="SaveButton_Click"
                            Background="{StaticResource SuccessBrush}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            TabIndex="3">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="حفظ الملاحظة"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CancelButton" 
                            Click="CancelButton_Click"
                            Style="{StaticResource CancelButtonStyle}"
                            TabIndex="4">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="إلغاء"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
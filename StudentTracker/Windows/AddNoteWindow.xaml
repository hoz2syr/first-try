<Window x:Class="StudentTracker.Windows.AddNoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="إضافة ملاحظة"
        Height="580"
        Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.Resources>
        <!-- ========== Modern Color Palette ========== -->
        <Color x:Key="PrimaryColor">#6366F1</Color>
        <Color x:Key="PrimaryDarkColor">#4F46E5</Color>
        <Color x:Key="PrimaryLightColor">#818CF8</Color>
        <Color x:Key="SuccessColor">#10B981</Color>
        <Color x:Key="WarningColor">#F59E0B</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="InfoColor">#0EA5E9</Color>
        
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
        
        <!-- ========== Modern Button Style ========== -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="22,12" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#000000" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8" />
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>
        
        <!-- ========== Modern TextBox Style ========== -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" Color="#000000" Direction="270" />
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="border" Property="Background" Value="#FEFEFE" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Color="#6366F1" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="30,22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0" />
                    <GradientStop Color="#4F46E5" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#000000" Direction="270" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="White" CornerRadius="14" Padding="14" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                    </Border.Effect>
                    <iconPacks:PackIconMaterial Kind="NoteEdit" Width="30" Height="30" Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إضافة ملاحظة جديدة" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="سجّل أفكارك وملاحظاتك المهمة" FontSize="14" Foreground="#C7D2FE" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,25">
                <!-- Title -->
                <StackPanel Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="FormatTitle" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="عنوان الملاحظة" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                    </StackPanel>
                    <TextBox x:Name="TitleTextBox" 
                             Height="50" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             MaxLength="100"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             FontWeight="SemiBold"
                             FontSize="16"
                             TabIndex="0"
                             ToolTip="أدخل عنوان الملاحظة (مطلوب)"/>
                    <TextBlock Text="مثال: ملاحظات المحاضرة، أفكار المشروع، تذكيرات مهمة" 
                               FontSize="12" 
                               Foreground="#6B7280" 
                               Margin="5,5,0,0"
                               FontStyle="Italic"/>
                </StackPanel>

                <!-- Content -->
                <StackPanel Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="TextBox" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="محتوى الملاحظة" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                        <TextBlock Text="*" Foreground="#EF4444" FontWeight="Bold" FontSize="16" Margin="4,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="ContentTextBox" 
                             MinHeight="200"
                             MaxHeight="400"
                             Style="{StaticResource ModernTextBoxStyle}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             MaxLength="2000"
                             TabIndex="1"
                             Text=""
                             ToolTip="اكتب محتوى الملاحظة هنا (مطلوب)"
                             SpellCheck.IsEnabled="True"/>
                    <StackPanel Orientation="Horizontal" Margin="5,8,0,0">
                        <TextBlock Text="💡 نصيحة: استخدم Enter لسطر جديد، يمكنك كتابة قوائم ونقاط" 
                                   FontSize="12" 
                                   Foreground="#6B7280" 
                                   FontStyle="Italic"/>
                        <TextBlock x:Name="CharacterCountText" 
                                   Text="0/2000" 
                                   FontSize="12" 
                                   Foreground="#9CA3AF" 
                                   HorizontalAlignment="Right"
                                   FontWeight="SemiBold"
                                   Margin="15,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Date -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="Calendar" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تاريخ الملاحظة" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                    </StackPanel>
                    <DatePicker x:Name="NoteDatePicker" 
                               Height="50"
                               FontSize="14"
                               BorderBrush="#E2E8F0" 
                               BorderThickness="2"
                               Background="White"
                               SelectedDate="{x:Static sys:DateTime.Today}"
                               TabIndex="2"
                               ToolTip="اختر تاريخ الملاحظة">
                        <DatePicker.Resources>
                            <Style TargetType="DatePicker">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DatePicker">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Padding="15,12">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" Color="#000000" Direction="270" />
                                                </Border.Effect>
                                                <DatePickerTextBox x:Name="PART_TextBox" 
                                                                   Background="Transparent" 
                                                                   BorderThickness="0" 
                                                                   FontSize="14"
                                                                   VerticalContentAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6" />
                                                    <Setter TargetName="border" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3B82F6" Direction="270" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                    <TextBlock Text="التاريخ الافتراضي هو اليوم" 
                               FontSize="12" 
                               Foreground="#6B7280" 
                               Margin="5,5,0,0"
                               FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="White" Padding="30,20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel>
                <!-- Help Text -->
                <Border Background="#EFF6FF" BorderBrush="{StaticResource InfoBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="16" Height="16" Foreground="{StaticResource InfoBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="12" Foreground="#1E40AF">
                            <Run Text="نصائح:" FontWeight="SemiBold"/>
                            <Run Text="Ctrl+Enter للحفظ • Esc للإلغاء • يجب إدخال عنوان ومحتوى الملاحظة"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SaveButton" 
                            Click="SaveButton_Click"
                            Background="{StaticResource SuccessBrush}"
                            Style="{StaticResource ModernButtonStyle}"
                            TabIndex="3">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="حفظ الملاحظة"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CancelButton" 
                            Click="CancelButton_Click"
                            Background="#64748B"
                            Style="{StaticResource ModernButtonStyle}"
                            TabIndex="4">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="إلغاء"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
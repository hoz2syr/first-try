<Window x:Class="StudentTracker.Windows.AddGradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:StudentTracker.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        FlowDirection="RightToLeft"
        Title="إدخال علامة"
        Height="500"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <!-- الأنماط الخاصة (RadioButtonStyle) تم نقلها إلى Resources/Styles.xaml -->
    
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,20" CornerRadius="16,16,0,0"
                    Background="{StaticResource HeaderGradientBrush}">
                <StackPanel>
                    <TextBlock Text="المادة" FontSize="13" Foreground="#C7D2FE" />
                    <TextBlock Text="{Binding SubjectName}" FontWeight="Bold" FontSize="20" Foreground="White" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20">
                    <!-- نوع العلامة -->
                    <GroupBox Header="نوع العلامة" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="12,10">
                            <RadioButton x:Name="PracticalRadio" Content="عملي" IsChecked="True" Style="{StaticResource RadioButtonStyle}" />
                            <RadioButton x:Name="TheoryRadio" Content="نظري" Style="{StaticResource RadioButtonStyle}" />
                        </StackPanel>
                    </GroupBox>

                    <!-- العلامة -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="العلامة" FontWeight="SemiBold" Margin="0,0,0,8" 
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GradeTextBox" 
                                     Grid.Column="0"
                                     Style="{StaticResource ValidatedTextBoxStyle}" 
                                     Tag="أدخل العلامة" 
                                     Width="180" 
                                     HorizontalAlignment="Center" 
                                     FontSize="18"
                                     Padding="12,10"
                                     HorizontalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text=" / " FontSize="20" FontWeight="Bold" 
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="100" FontSize="20" FontWeight="Bold" 
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <TextBlock Text="أدخل رقماً بين 0 و 100" FontSize="11" 
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" 
                                   Margin="0,6,0,0" FontStyle="Italic"/>
                    </StackPanel>

                    <!-- التاريخ -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="التاريخ" Margin="0,0,0,8" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                        <controls:DateWheelPicker x:Name="DatePickerControl"
                                                  SelectedDate="{Binding AttemptDate, Mode=OneWay}"
                                                  Width="340"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- ملاحظات -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="ملاحظات (اختياري)" Margin="0,0,0,8" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                        <TextBox x:Name="NotesTextBox" 
                                 AcceptsReturn="True" 
                                 Height="90" 
                                 TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto" 
                                 Style="{StaticResource ValidatedTextBoxStyle}" 
                                 Tag="أضف ملاحظاتك هنا (اختياري)" 
                                 VerticalContentAlignment="Top"
                                 Padding="12,10" />
                    </StackPanel>

                    <!-- الأزرار -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Width="130" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="حفظ"/>
                            </StackPanel>
                        </Button>
                        <Button Width="130" Style="{StaticResource CancelButtonStyle}" Click="Cancel_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="إلغاء"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>


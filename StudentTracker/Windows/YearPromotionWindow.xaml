<Window x:Class="StudentTracker.Windows.YearPromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="مبروك الترفع"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="650"
        Height="480"
        ResizeMode="NoResize">
    <Border Background="#EEF2F7" CornerRadius="20">
        <Grid>
            <!-- Background overlay -->
            <Border Background="#80000000" CornerRadius="20" Opacity="0.5" />
            
            <!-- Main content -->
            <Border CornerRadius="20" Margin="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="0.5" />
                        <GradientStop Color="#0288D1" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <!-- Confetti decoration -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" Opacity="0.3">
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="StarOutline" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="StarOutline" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                        <iconPacks:PackIconMaterial Kind="PartyPopper" Width="24" Height="24" Foreground="White" Margin="4,0"/>
                    </StackPanel>
                    
                    <!-- Main content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Icon -->
                        <TextBlock FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,16" >
                    <iconPacks:PackIconMaterial Kind="School" Width="72" Height="72" Foreground="#FFD700"/>
                </TextBlock>
                        
                        <!-- Title -->
                        <TextBlock Text="مبروك الترفع!" 
                                   FontSize="42" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black" />
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <!-- Subtitle -->
                        <TextBlock Text="لقد أتممت متطلبات السنة الدراسية بنجاح" 
                                   FontSize="20" 
                                   Foreground="#BBDEFB" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,8,0,0" />
                        
                        <!-- Year badge -->
                        <Border Background="#40FFFFFF" 
                                BorderBrush="#66FFFFFF" 
                                BorderThickness="2" 
                                CornerRadius="50" 
                                Padding="16,8" 
                                Margin="20,20,0,32"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="YearTextBlock" 
                                       Text="السنة الثالثة" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="White" />
                        </Border>
                        
                        <!-- Continue button -->
                        <Button Click="Continue_Click"
                                HorizontalAlignment="Center"
                                Padding="24,14"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="White"
                                Foreground="#1A237E"
                                BorderThickness="0"
                                Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowRightBold" Width="18" Height="18" Margin="0,0,8,0" Foreground="#1A237E"/>
                            <TextBlock Text="متابعة المسيرة"/>
                        </StackPanel>
                    </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


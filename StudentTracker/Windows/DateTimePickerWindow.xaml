<Window x:Class="StudentTracker.Windows.DateTimePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudentTracker.Controls"
        Title="التاريخ والوقت" Width="400" Height="780"
        Background="#FF000000" WindowStyle="None"
        AllowsTransparency="True" ResizeMode="NoResize"
        FlowDirection="RightToLeft" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FFFF9F0A"/>
        <Style x:Key="ConfirmButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFF9F0A"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#FFE08C00"/></Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FFFFB030"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#FF000000" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,48,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="BackButton_Click" Background="Transparent" Foreground="#FFFF9F0A" FontSize="15" BorderThickness="0" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="›" FontSize="22" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="رجوع" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="التاريخ والوقت" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Display -->
            <StackPanel Grid.Row="1" Margin="0,12,0,20" HorizontalAlignment="Center">
                <TextBlock x:Name="DateDisplayText" Text="— —" Foreground="White" FontSize="40" FontWeight="Light" HorizontalAlignment="Center" TextAlignment="Center"/>
                <TextBlock x:Name="TimeDisplayText" Text="— : —" Foreground="#99FFFFFF" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <Rectangle Grid.Row="2" Height="1" Fill="#14FFFFFF" Margin="24,0"/>

            <!-- Date section -->
            <TextBlock Grid.Row="3" Text="التاريخ" Foreground="#FFFF9F0A" FontSize="11" Margin="24,16,24,4"/>
            <Grid Grid.Row="4" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="اليوم" Foreground="#44FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <controls:WheelPickerControl x:Name="DayPicker" HorizontalAlignment="Stretch" SelectionChanged="Picker_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="الشهر" Foreground="#44FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <controls:WheelPickerControl x:Name="MonthPicker" HorizontalAlignment="Stretch" SelectionChanged="Picker_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="السنة" Foreground="#44FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <controls:WheelPickerControl x:Name="YearPicker" HorizontalAlignment="Stretch" SelectionChanged="Picker_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="5" Height="1" Fill="#14FFFFFF" Margin="24,16,24,0"/>

            <!-- Time section -->
            <TextBlock Grid.Row="6" Text="الوقت" Foreground="#FFFF9F0A" FontSize="11" Margin="24,14,24,4"/>
            <Grid Grid.Row="7" Margin="8,0" HorizontalAlignment="Center" Width="240">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="الساعة" Foreground="#44FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <controls:WheelPickerControl x:Name="HourPicker" HorizontalAlignment="Stretch" SelectionChanged="Picker_SelectionChanged"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text=":" Foreground="White" FontSize="28" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الدقيقة" Foreground="#44FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <controls:WheelPickerControl x:Name="MinutePicker" HorizontalAlignment="Stretch" SelectionChanged="Picker_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Confirm button -->
            <Button Grid.Row="9" x:Name="ConfirmButton" Content="تأكيد"
                    Style="{StaticResource ConfirmButtonStyle}"
                    Margin="20,12,20,32" Click="ConfirmButton_Click"/>
        </Grid>
    </Border>
</Window>
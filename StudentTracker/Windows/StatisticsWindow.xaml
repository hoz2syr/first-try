<Window x:Class="StudentTracker.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="الإحصائيات المفصلة"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8FAFC"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Modern Color Palette -->
        <Color x:Key="PrimaryColor">#6366F1</Color>
        <Color x:Key="SuccessColor">#10B981</Color>
        <Color x:Key="WarningColor">#F59E0B</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="InfoColor">#0EA5E9</Color>
        
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
        
        <!-- Card Style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#000000" Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Progress Bar Style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Border x:Name="PART_Track" CornerRadius="6">
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="6"
                                        HorizontalAlignment="Left" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="30,25" CornerRadius="0,0,20,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0" />
                    <GradientStop Color="#8B5CF6" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#000000" Direction="270" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,20,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                    </Border.Effect>
                    <iconPacks:PackIconMaterial Kind="ChartLine" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="📊  الإحصائيات المفصلة" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="تحليل شامل لأدائك الأكاديمي" FontSize="16" Foreground="#E0E7FF" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- Overall Statistics -->
                <TextBlock Text="📈  الإحصائيات العامة" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="12,0,12,16"/>
                
                <UniformGrid Columns="3" Rows="2">
                    <!-- Total Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#EFF6FF" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="BookOpenPageVariant" Width="24" Height="24" Foreground="{StaticResource InfoBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="إجمالي المواد" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="TotalSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1F2937"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Passed Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#ECFDF5" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="CheckCircle" Width="24" Height="24" Foreground="{StaticResource SuccessBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="المواد الناجحة" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="PassedSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#059669"/>
                                </StackPanel>
                            </StackPanel>
                            <ProgressBar x:Name="PassedProgressBar" Style="{StaticResource ModernProgressBarStyle}" 
                                         Foreground="{StaticResource SuccessBrush}" Value="0" Maximum="100"/>
                            <TextBlock x:Name="PassedPercentageText" Text="0%" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Failed Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF2F2" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="CloseCircle" Width="24" Height="24" Foreground="{StaticResource DangerBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="المواد الراسبة" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="FailedSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#DC2626"/>
                                </StackPanel>
                            </StackPanel>
                            <ProgressBar x:Name="FailedProgressBar" Style="{StaticResource ModernProgressBarStyle}" 
                                         Foreground="{StaticResource DangerBrush}" Value="0" Maximum="100"/>
                            <TextBlock x:Name="FailedPercentageText" Text="0%" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Average Grade -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF3C7" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="Star" Width="24" Height="24" Foreground="{StaticResource WarningBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="المعدل العام" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="AverageGradeText" Text="0.0" FontSize="28" FontWeight="Bold" Foreground="#D97706"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Pending Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF3C7" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="24" Height="24" Foreground="{StaticResource WarningBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="المواد المعلقة" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="PendingSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#D97706"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Remaining Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#F3F4F6" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="BookOutline" Width="24" Height="24" Foreground="#6B7280"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="المواد المتبقية" FontSize="14" Foreground="#6B7280"/>
                                    <TextBlock x:Name="RemainingSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#6B7280"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Year-wise Statistics -->
                <TextBlock Text="📅  الإحصائيات حسب السنة" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="12,32,12,16"/>
                
                <ItemsControl x:Name="YearStatisticsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatCardStyle}" Margin="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Background="#F0F9FF" CornerRadius="12" Padding="16" Margin="0,0,20,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="School" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding YearNumber, StringFormat='السنة {0}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding PassedCount}" FontSize="24" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                                <TextBlock Text="ناجحة" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding FailedCount}" FontSize="24" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                                                <TextBlock Text="راسبة" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center"/>
                                                <TextBlock Text="معلقة" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RemainingCount}" FontSize="24" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                                <TextBlock Text="متبقية" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <ProgressBar Value="{Binding CompletionPercentage}" Maximum="100" 
                                                     Style="{StaticResource ModernProgressBarStyle}" 
                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="{Binding CompletionPercentage, StringFormat='{}{0:0.#}% مكتملة'}" 
                                                   FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseButton" Click="CloseButton_Click" Padding="24,12" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="إغلاق"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
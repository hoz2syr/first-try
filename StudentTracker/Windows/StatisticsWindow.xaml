<Window x:Class="StudentTracker.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        FlowDirection="RightToLeft"
        Title="ط§ظ„ط¥ط­طµط§ط¦ظٹط§طھ ط§ظ„ظ…ظپطµظ„ط©"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- â•گâ•گâ•گ ط£ظ†ظ…ط§ط· ط®ط§طµط© ط¨ظ†ط§ظپط°ط© ط§ظ„ط¥ط­طµط§ط¦ظٹط§طھ â•گâ•گâ•گ -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
        </Style>
        <!-- ModernProgressBarStyle ظ…ظڈط¹ط±ظ‘ظپ ظ…ط±ظƒط²ظٹط§ظ‹ ظپظٹ Resources/Styles.xaml -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="30,25" CornerRadius="0,0,20,20"
                Background="{StaticResource StatsHeaderGradientBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#000000" Direction="270" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,20,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#6366F1" />
                    </Border.Effect>
                    <iconPacks:PackIconMaterial Kind="ChartLine" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ًں“ٹ  ط§ظ„ط¥ط­طµط§ط¦ظٹط§طھ ط§ظ„ظ…ظپطµظ„ط©" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="طھط­ظ„ظٹظ„ ط´ط§ظ…ظ„ ظ„ط£ط¯ط§ط¦ظƒ ط§ظ„ط£ظƒط§ط¯ظٹظ…ظٹ" FontSize="16" Foreground="#E0E7FF" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- Overall Statistics -->
                <TextBlock Text="ًں“ˆ  ط§ظ„ط¥ط­طµط§ط¦ظٹط§طھ ط§ظ„ط¹ط§ظ…ط©" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="12,0,12,16"/>
                
                <UniformGrid Columns="3" Rows="2">
                    <!-- Total Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#EFF6FF" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="BookOpenPageVariant" Width="24" Height="24" Foreground="{StaticResource InfoBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط¥ط¬ظ…ط§ظ„ظٹ ط§ظ„ظ…ظˆط§ط¯" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="TotalSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Passed Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#ECFDF5" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="CheckCircle" Width="24" Height="24" Foreground="{StaticResource SuccessBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط§ظ„ظ…ظˆط§ط¯ ط§ظ„ظ†ط§ط¬ط­ط©" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PassedSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessDarkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <ProgressBar x:Name="PassedProgressBar" Style="{StaticResource ModernProgressBarStyle}" 
                                         Foreground="{StaticResource SuccessBrush}" Value="0" Maximum="100"/>
                            <TextBlock x:Name="PassedPercentageText" Text="0%" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Failed Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF2F2" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="CloseCircle" Width="24" Height="24" Foreground="{StaticResource DangerBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط§ظ„ظ…ظˆط§ط¯ ط§ظ„ط±ط§ط³ط¨ط©" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="FailedSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerDarkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <ProgressBar x:Name="FailedProgressBar" Style="{StaticResource ModernProgressBarStyle}" 
                                         Foreground="{StaticResource DangerBrush}" Value="0" Maximum="100"/>
                            <TextBlock x:Name="FailedPercentageText" Text="0%" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Average Grade -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF3C7" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="Star" Width="24" Height="24" Foreground="{StaticResource WarningBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط§ظ„ظ…ط¹ط¯ظ„ ط§ظ„ط¹ط§ظ…" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="AverageGradeText" Text="0.0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Pending Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FEF3C7" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="24" Height="24" Foreground="{StaticResource WarningBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط§ظ„ظ…ظˆط§ط¯ ط§ظ„ظ…ط¹ظ„ظ‚ط©" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PendingSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Remaining Subjects -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#F3F4F6" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterial Kind="BookOutline" Width="24" Height="24" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ط§ظ„ظ…ظˆط§ط¯ ط§ظ„ظ…طھط¨ظ‚ظٹط©" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="RemainingSubjectsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Year-wise Statistics -->
                <TextBlock Text="ًں“…  ط§ظ„ط¥ط­طµط§ط¦ظٹط§طھ ط­ط³ط¨ ط§ظ„ط³ظ†ط©" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="12,32,12,16"/>
                
                <ItemsControl x:Name="YearStatisticsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatCardStyle}" Margin="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Background="#F0F9FF" CornerRadius="12" Padding="16" Margin="0,0,20,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="School" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding YearNumber, StringFormat='ط§ظ„ط³ظ†ط© {0}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding PassedCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessDarkBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="ظ†ط§ط¬ط­ط©" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding FailedCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DangerDarkBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="ط±ط§ط³ط¨ط©" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="ظ…ط¹ظ„ظ‚ط©" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RemainingCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="ظ…طھط¨ظ‚ظٹط©" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <ProgressBar Value="{Binding CompletionPercentage}" Maximum="100" 
                                                     Style="{StaticResource ModernProgressBarStyle}" 
                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="{Binding CompletionPercentage, StringFormat='{}{0:0.#}% ظ…ظƒطھظ…ظ„ط©'}" 
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseButton" Click="CloseButton_Click" 
                        Background="{StaticResource PrimaryBrush}" 
                        Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="ط¥ط؛ظ„ط§ظ‚"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="StudentTracker.Windows.ChangeSemesterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="تغيير الفصل الحالي"
        Height="400"
        Width="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="#EEF2F7" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock FontWeight="Bold" FontSize="18" Foreground="White" >
                    <iconPacks:PackIconMaterial Kind="Sync" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Run Text="تغيير الفصل الحالي"/>
                </TextBlock>
            </Border>

            <Grid Grid.Row="1" Margin="18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="السنة الدراسية الحالية (قراءة فقط):" FontWeight="Bold" />

                <ComboBox x:Name="YearComboBox" Grid.Row="1" Margin="0,8,0,6" Padding="8,6" FontSize="14" />

                <TextBlock Grid.Row="2" Foreground="#607D8B" FontSize="12"
                           Text="السنة يتم حسابها تلقائياً بناءً على عدد المواد الناجحة" />

                <TextBlock Grid.Row="3" Text="الفصل الدراسي:" FontWeight="Bold" Margin="0,12,0,0" />

                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <RadioButton x:Name="Semester1Radio" Content="الفصل الأول" Margin="0,0,0,8" />
                    <RadioButton x:Name="Semester2Radio" Content="الفصل الثاني" Margin="0,0,0,8" />
                    <RadioButton x:Name="SummerRadio" Content="الفصل الصيفي" />
                </StackPanel>

                <Border Grid.Row="5" Background="#FFF8E1" BorderBrush="#FFB300" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Alert" Width="16" Height="16" VerticalAlignment="Top" Margin="0,0,8,0" Foreground="#FF9800"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#795548"
                                   Text="تغيير الفصل سيؤثر على المواد المعروضة في مخطط الفصل الحالي." />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Width="110" Click="Confirm_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Check" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="تأكيد"/>
                    </StackPanel>
                </Button>
                <Button Width="110" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>


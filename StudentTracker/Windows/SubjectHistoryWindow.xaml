<Window x:Class="StudentTracker.Windows.SubjectHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="سجل المادة"
        Height="540"
        Width="720"
        WindowStartupLocation="CenterOwner">
    <Border Background="#EEF2F7" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A237E" Offset="0" />
                        <GradientStop Color="#1565C0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="{Binding SubjectTitle}" FontWeight="Bold" FontSize="20" Foreground="White" />
            </Border>

            <Grid Grid.Row="1" Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding Attempts}" AutoGenerateColumns="False"
                         Background="White"
                         BorderBrush="#E3E8EF"
                         BorderThickness="1"
                         GridLinesVisibility="Horizontal"
                         HorizontalGridLinesBrush="#E3E8EF"
                         RowBackground="White"
                         AlternatingRowBackground="#F5F8FC"
                         HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="النوع" Binding="{Binding AttemptType}" Width="*" />
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding AttemptDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="*" />
                        <DataGridTextColumn Header="العلامة" Binding="{Binding Grade}" Width="*" />
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="2*" />
                    </DataGrid.Columns>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F5F7FA" />
                            <Setter Property="Foreground" Value="#546E7A" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="BorderBrush" Value="#E3E8EF" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                </DataGrid>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,10,0,4">
                    <StackPanel>
                        <TextBlock Text="📊 الملخص" FontWeight="Bold" FontSize="16" Foreground="#1A237E" Margin="0,0,0,8" />
                        <WrapPanel>
                            <Border Background="#F0F4F8" CornerRadius="8" Padding="10,6" Margin="0,0,10,0">
                                <TextBlock>
                                    <Run Text="آخر علامة عملية: " FontWeight="SemiBold" />
                                    <Run Text="{Binding LatestPracticalGradeText, Mode=OneWay}" FontWeight="Bold" Foreground="#1565C0" />
                                </TextBlock>
                            </Border>
                            <Border Background="#F0F4F8" CornerRadius="8" Padding="10,6" Margin="0,0,10,0">
                                <TextBlock>
                                    <Run Text="آخر علامة نظرية: " FontWeight="SemiBold" />
                                    <Run Text="{Binding LatestTheoryGradeText, Mode=OneWay}" FontWeight="Bold" Foreground="#1565C0" />
                                </TextBlock>
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="10,6">
                                <TextBlock>
                                    <Run Text="المجموع: " FontWeight="SemiBold" />
                                    <Run Text="{Binding LatestFinalGradeText, Mode=OneWay}" FontWeight="Bold" Foreground="#2E7D32" />
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="130" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="إغلاق"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

